# Postgres — only change these if you want non-default credentials.
POSTGRES_USER=marquee
POSTGRES_PASSWORD=change_me
POSTGRES_DB=marquee
POSTGRES_PORT=5432

# Only used for `npm run dev` on the host; inside Docker Compose the app
# talks to Postgres via the `postgres` service name instead of localhost.
DATABASE_URL=postgres://marquee:change_me@localhost:5432/marquee

# Any long random string. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base64-encoded 32-byte key used to encrypt saved Sonarr/Radarr/Plex
# credentials at rest. Generate with: openssl rand -base64 32
# Back this up — losing it makes previously saved credentials undecryptable.
MASTER_ENCRYPTION_KEY=

# From https://www.themoviedb.org/settings/api — either the v4 access token
# or the v3 API key works.
TMDB_ACCESS_TOKEN=
TMDB_API_KEY=

# From https://thetvdb.com/api-information — used to cross-reference
# Sonarr's TVDB ids to TMDb.
TVDB_API_KEY=
TVDB_PIN=

# App port when running via Docker Compose (defaults to 3000).
APP_PORT=3000
